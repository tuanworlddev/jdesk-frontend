{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "node scripts/generate-csp.mjs",
    "preview": "node scripts/serve-static.mjs",
    "start": "npm run preview",
    "lint": "eslint --max-warnings=0",
